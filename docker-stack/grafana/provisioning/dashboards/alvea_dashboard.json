    "from": "now-5m",
    "to": "now"
  },
  "panels": [
    {
      "id": 2,
      "type": "stat",
      "title": "Freq. Respiratoria (Atti/min)",
      "datasource": {
        "type": "influxdb",
        "uid": "alvea_influx"
      },
      "gridPos": {
        "h": 6,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              },
              {
                "color": "green",
                "value": 20
              },
              {
                "color": "orange",
                "value": 31
              },
              {
                "color": "red",
                "value": 41
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "alvea_influx"
          },
          "query": "from(bucket: \"vitals\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"vitals\" and r._field == \"respiration_rate\")\n  |> filter(fn: (r) => r._value > 0)\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)",
          "refId": "A"
        }
      ]
    },
